---
import { landingContent, siteConfig } from '../../content/landing';
const { footer } = landingContent;
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark border-t border-white/8">

  <!-- Main footer grid -->
  <div class="max-w-6xl mx-auto px-6 py-16 grid sm:grid-cols-2 lg:grid-cols-4 gap-12">

    <!-- Brand column -->
    <div class="lg:col-span-2">
      <a href="/" class="flex items-center gap-2.5 mb-4">
        <img src="/Logo.jpeg" alt="Education AI logo" class="h-8 w-8 rounded-md object-contain" width="32" height="32" loading="lazy" decoding="async" />
        <span class="font-display font-semibold text-white tracking-tight">
          Education <span class="text-primary-300">AI</span>
        </span>
      </a>
      <p class="text-sm text-brand-gray leading-relaxed max-w-sm mb-6">
        {footer.tagline}
      </p>
      <!-- Social links -->
      <div class="flex gap-3">
        <a
          href={siteConfig.twitterUrl}
          target="_blank"
          rel="noreferrer noopener"
          class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center text-brand-gray hover:text-white hover:bg-white/15 transition-colors"
          aria-label="Twitter / X"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a
          href={siteConfig.linkedInUrl}
          target="_blank"
          rel="noreferrer noopener"
          class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center text-brand-gray hover:text-white hover:bg-white/15 transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href={siteConfig.youtubeUrl}
          target="_blank"
          rel="noreferrer noopener"
          class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center text-brand-gray hover:text-white hover:bg-white/15 transition-colors"
          aria-label="YouTube"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Product column -->
    <div>
      <h4 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">Product</h4>
      <ul class="space-y-2.5">
        {footer.productLinks.map((link) => (
          <li>
            <a
              href={link.href}
              {...link.external ? { target: '_blank', rel: 'noreferrer noopener' } : {}}
              class="text-sm text-brand-gray hover:text-white transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Company column -->
    <div>
      <h4 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">Company</h4>
      <ul class="space-y-2.5">
        {footer.companyLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-brand-gray hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-wrap items-center justify-between gap-4">
      <p class="text-xs text-brand-gray">
        &copy; {year} {footer.copyright}. All rights reserved.
      </p>
      <nav class="flex gap-5" aria-label="Legal links">
        {footer.legalLinks.map((link) => (
          link.modalKey ? (
            <button
              type="button"
              onclick={`document.dispatchEvent(new CustomEvent('open-legal-dialog', { detail: '${link.modalKey}' }))`}
              class="text-xs text-brand-gray hover:text-white transition-colors bg-transparent border-0 p-0 cursor-pointer"
            >
              {link.label}
            </button>
          ) : (
            <a href={link.href} class="text-xs text-brand-gray hover:text-white transition-colors">
              {link.label}
            </a>
          )
        ))}
      </nav>
    </div>
  </div>

</footer>
