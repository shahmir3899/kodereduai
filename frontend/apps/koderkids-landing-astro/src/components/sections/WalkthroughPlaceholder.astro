---
/**
 * WalkthroughPlaceholder.astro
 * Phase 2 static shell: shows the first slide only.
 * Phase 3 will replace this with the full interactive island (React + GSAP carousel).
 */
import { landingContent } from '../../content/landing';
const { walkthrough } = landingContent;

const firstSlide = walkthrough.slides[0];
const allLabels = walkthrough.slides.map((s) => s.label);
---

<section id="walkthrough" class="py-24 bg-brand-light">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="section-label mb-3 block">{walkthrough.label}</span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-dark mb-4">
        {walkthrough.heading}
      </h2>
      <p class="text-brand-gray text-lg">{walkthrough.subheading}</p>
    </div>

    <!-- Tab pills (static — first tab highlighted, others inactive) -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" role="tablist" aria-label="Feature walkthrough tabs">
      {allLabels.map((label, i) => (
        <span
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          class={[
            'px-4 py-1.5 rounded-full text-sm font-medium transition-colors cursor-default',
            i === 0
              ? 'bg-primary text-white shadow-sm'
              : 'bg-white text-brand-gray border border-gray-200',
          ].join(' ')}
        >
          {label}
        </span>
      ))}
    </div>

    <!-- First slide preview -->
    <div class="grid lg:grid-cols-2 gap-10 items-start">

      <!-- Screenshot in browser frame -->
      <div class="dashboard-card">
        <div class="window-chrome">
          <span class="window-dot window-dot-red"></span>
          <span class="window-dot window-dot-yellow"></span>
          <span class="window-dot window-dot-green"></span>
          <div class="ml-3 flex-1 h-5 bg-gray-100 rounded-md text-xs text-gray-400 flex items-center px-3 max-w-xs">
            app.kodereduai.pk / {firstSlide.id}
          </div>
        </div>
        <img
          src={firstSlide.image}
          alt={`${firstSlide.label} screen — ${firstSlide.title}`}
          class="w-full block"
          loading="lazy"
          decoding="async"
          width="900"
          height="560"
        />
      </div>

      <!-- Slide content -->
      <div class="flex flex-col justify-center py-4">
        <h3 class="font-display text-2xl font-bold text-brand-dark mb-3">
          {firstSlide.title}
        </h3>
        <p class="text-brand-gray leading-relaxed mb-6">
          {firstSlide.description}
        </p>
        <ul class="space-y-3">
          {firstSlide.bullets.map((bullet) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-primary-50 flex items-center justify-center">
                <svg class="w-3 h-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="text-sm text-brand-dark leading-relaxed">{bullet}</span>
            </li>
          ))}
        </ul>

        <!-- Phase notice -->
        <p class="mt-8 text-xs text-brand-gray/60 italic">
          Interactive carousel (tab switching &amp; auto-play) available in the full demo →
          <a href="#contact" class="text-primary underline underline-offset-2 not-italic font-medium">Book a Demo</a>
        </p>
      </div>

    </div>

  </div>
</section>
