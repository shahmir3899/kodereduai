---
import { landingContent, siteConfig } from '../../content/landing';
import ContactForm from '../islands/ContactForm.tsx';
const { finalCta } = landingContent;
---

<section id="contact" class="py-24 bg-brand-dark">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: copy -->
      <div>
        <span class="section-label text-primary-300 mb-4 block">{finalCta.label}</span>

        <h2 class="font-display text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">
          {finalCta.heading}
        </h2>
        <p class="text-brand-gray text-lg leading-relaxed mb-8">
          {finalCta.subheading}
        </p>

        <!-- Chips -->
        <div class="flex flex-wrap gap-2 mb-10">
          {finalCta.chips.map((chip) => (
            <span class="text-xs font-medium px-3 py-1.5 rounded-full bg-white/8 text-gray-300 border border-white/10">
              {chip}
            </span>
          ))}
        </div>

        <div class="mb-10 space-y-1.5 text-sm text-gray-300">
          <p>Email: <a href={`mailto:${siteConfig.salesEmail}`} class="text-primary-300 hover:text-primary-200">{siteConfig.salesEmail}</a></p>
          <p>Phone: <a href={`tel:${siteConfig.contactPhone}`} class="text-primary-300 hover:text-primary-200">{siteConfig.contactPhone}</a></p>
          <p>City: {siteConfig.contactCity}</p>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-3">
          <button
            type="button"
            onclick="document.dispatchEvent(new CustomEvent('open-demo-dialog'))"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-full hover:bg-primary-600 transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_25px_rgba(43,106,255,0.4)] text-[0.9375rem] border-0 cursor-pointer"
          >
            {finalCta.primaryCta.label}
          </button>
          <a
            href={finalCta.secondaryCta.href}
            target="_blank"
            rel="noreferrer noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold rounded-full border border-white/20 hover:bg-white/15 transition-all text-[0.9375rem]"
          >
            {finalCta.secondaryCta.label}
            <svg class="w-3.5 h-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: React contact form island -->
      <ContactForm client:visible />
    </div>
  </div>
</section>
