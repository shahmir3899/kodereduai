---
import { landingContent, siteConfig } from '../../content/landing';
const { hero } = landingContent;
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-brand-dark pt-16">

  <!-- Background: giant watermark "K" -->
  <div
    class="pointer-events-none select-none absolute right-[-4rem] top-1/2 -translate-y-1/2 text-[32rem] font-display font-bold leading-none opacity-[0.04] text-white"
    aria-hidden="true"
  >K</div>

  <!-- Gradient blobs -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] rounded-full bg-primary/8 blur-[120px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-violet-500/6 blur-[100px]"></div>
  </div>

  <div class="relative z-10 w-full max-w-[1800px] mx-auto px-6 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="section-label text-primary-300 mb-4 block">{hero.label}</span>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.08] tracking-tight mb-6">
          {hero.heading}
        </h1>

        <p class="text-brand-gray text-lg leading-relaxed max-w-xl mb-10">
          {hero.subheading}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mb-12">
          <button
            type="button"
            onclick="document.dispatchEvent(new CustomEvent('open-demo-dialog'))"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-full hover:bg-primary-600 transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_25px_rgba(43,106,255,0.4)] text-[0.9375rem] border-0 cursor-pointer"
          >
            {hero.primaryCta.label}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
          <a
            href={hero.secondaryCta.href}
            class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold rounded-full border border-white/20 hover:bg-white/15 transition-all text-[0.9375rem]"
          >
            {hero.secondaryCta.label}
          </a>
        </div>

        <!-- Trust bar: static metrics -->
        <div class="flex flex-wrap gap-6">
          <div>
            <div class="text-2xl font-display font-bold text-white">{hero.metrics.schools}</div>
            <div class="text-xs text-brand-gray mt-0.5">Schools</div>
          </div>
          <div class="w-px bg-white/10 self-stretch"></div>
          <div>
            <div class="text-2xl font-display font-bold text-white">{hero.metrics.students}</div>
            <div class="text-xs text-brand-gray mt-0.5">Students</div>
          </div>
          <div class="w-px bg-white/10 self-stretch"></div>
          <div>
            <div class="text-2xl font-display font-bold text-white">{hero.metrics.teachers}</div>
            <div class="text-xs text-brand-gray mt-0.5">Teachers</div>
          </div>
          <div class="w-px bg-white/10 self-stretch"></div>
          <div>
            <div class="text-2xl font-display font-bold text-white">{hero.metrics.countries}</div>
            <div class="text-xs text-brand-gray mt-0.5">Countries</div>
          </div>
        </div>
      </div>

      <!-- Right: dashboard screenshot in browser chrome frame -->
      <div class="relative">
        <div class="dashboard-card">
          <div class="window-chrome">
            <span class="window-dot window-dot-red"></span>
            <span class="window-dot window-dot-yellow"></span>
            <span class="window-dot window-dot-green"></span>
            <div class="ml-3 flex-1 h-5 bg-gray-100 rounded-md text-xs text-gray-400 flex items-center px-3 max-w-xs">
              app.kodereduai.pk
            </div>
          </div>
          <img
            src={hero.dashboardImage}
            alt={hero.dashboardAlt}
            class="w-full block"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            width="1200"
            height="750"
          />
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-card px-4 py-3 flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center">
            <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <div>
            <div class="text-xs font-semibold text-brand-dark">Attendance marked</div>
            <div class="text-xs text-brand-gray">42 students · 2 min ago</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
