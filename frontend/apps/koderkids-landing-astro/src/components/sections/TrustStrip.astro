---
import { landingContent } from '../../content/landing';
const { trustStrip } = landingContent;

const icons: Record<string, string> = {
  shield:  'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  network: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 0 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 0-2-2v-4m0 0h18',
  mobile:  'M17 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zM12 18h.01',
  zap:     'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
};
---

<section class="py-20 bg-brand-dark">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {trustStrip.items.map((item) => (
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-xl bg-white/8 flex items-center justify-center flex-shrink-0">
            <svg
              class="w-5 h-5 text-primary-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.icon] ?? icons.zap} />
            </svg>
          </div>
          <div>
            <div class="font-semibold text-white text-sm mb-1">{item.title}</div>
            <div class="text-xs text-brand-gray leading-relaxed">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
