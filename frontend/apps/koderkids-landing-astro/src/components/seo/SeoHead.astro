---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  robots?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  canonical,
  robots = 'index,follow',
  ogImage = '/hero_illustration.jpg',
  ogType = 'website',
  jsonLd,
} = Astro.props as Props;

const site = Astro.site;
const canonicalUrl = canonical ? new URL(canonical, site).toString() : undefined;
const ogImageUrl = new URL(ogImage, site).toString();

// Normalise jsonLd to an array so we can render multiple schemas cleanly
const schemas: object[] = jsonLd
  ? Array.isArray(jsonLd) ? jsonLd : [jsonLd]
  : [];
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="KoderKids" />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="KoderKids — Education AI for Schools" />
{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@koderkidspk" />
<meta name="twitter:creator" content="@koderkidspk" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content="KoderKids — Education AI for Schools" />

<!-- JSON-LD Structured Data -->
{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
