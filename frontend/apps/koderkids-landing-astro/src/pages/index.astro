---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingContent, siteConfig, faqContent } from '../content/landing';

import Nav                   from '../components/sections/Nav.astro';
import Hero                  from '../components/sections/Hero.astro';
import PlatformOverview      from '../components/sections/PlatformOverview.astro';
import SocialProof           from '../components/sections/SocialProof.astro';
import Pricing               from '../components/sections/Pricing.astro';
import TrustStrip            from '../components/sections/TrustStrip.astro';
import FinalCTA              from '../components/sections/FinalCTA.astro';
import Footer                from '../components/sections/Footer.astro';

import WalkthroughCarousel   from '../components/islands/WalkthroughCarousel.tsx';
import DemoDialog            from '../components/islands/DemoDialog.tsx';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.koderkids.pk';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'KoderKids',
  alternateName: 'KoderEduAI',
  url: siteUrl,
  logo: `${siteUrl}/Logo.jpeg`,
  sameAs: [
    siteConfig.twitterUrl,
    siteConfig.linkedInUrl,
    siteConfig.youtubeUrl,
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: siteConfig.salesEmail,
    contactType: 'sales',
    availableLanguage: 'English',
  },
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'KoderEduAI',
  operatingSystem: 'Web, iOS, Android',
  applicationCategory: 'EducationApplication',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Contact sales for pricing — multiple tiers available.',
  },
  description: landingContent.description,
  url: siteUrl,
  screenshot: `${siteUrl}/dashboard_overview.jpg`,
  featureList: [
    'AI-powered attendance from handwritten registers',
    'Admissions management',
    'Fee & finance management',
    'Academic timetabling',
    'Examination & report cards',
    'HR & payroll',
    'Transport & GPS tracking',
    'Parent & student portal',
    'Library management',
    'Hostel management',
    'Inventory management',
    'Multi-branch school support',
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqContent.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={landingContent.title}
  description={landingContent.description}
  canonical="/"
  jsonLd={[organizationSchema, softwareSchema, faqSchema]}
>
  <!-- Preload LCP image (hero dashboard screenshot) -->
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/dashboard_overview.jpg"
    fetchpriority="high"
  />

  <!-- Subtle noise texture overlay -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <Nav />

  <main id="main-content">
    <Hero />
    <PlatformOverview />
    <WalkthroughCarousel client:visible />
    <SocialProof />
    <Pricing />
    <TrustStrip />
    <FinalCTA />
  </main>

  <Footer />

  <!-- Global demo dialog island — listens for 'open-demo-dialog' custom events -->
  <DemoDialog client:idle />
</BaseLayout>
