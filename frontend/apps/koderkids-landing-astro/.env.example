# ─── KoderKids Landing (Astro) — Environment Variables ─────────────────────
#
# Copy this file to .env and fill in values before running locally or deploying.
# In Astro, only variables prefixed with PUBLIC_ are exposed to the browser.
# SITE_URL is used at build time to set the canonical base URL (og:url, sitemap).
#
# ─── Build-time ──────────────────────────────────────────────────────────────

# Canonical site URL — used for og:url, sitemap, and JSON-LD.
# No trailing slash.
SITE_URL=https://www.kodereduai.pk

# ─── Runtime (browser) — prefix PUBLIC_ required by Astro ───────────────────

# Base URL of the main KoderEduAI API.
# Optional now:
# - In local dev, empty uses /api with Astro proxy -> http://127.0.0.1:8000
# - In production build, empty defaults to https://kodereduai-api.onrender.com
PUBLIC_MAIN_APP_API_BASE_URL=https://kodereduai-api.onrender.com

# API path that returns landing metrics JSON.
PUBLIC_LANDING_METRICS_PATH=/api/public/landing-metrics/

# Optional school ID sent as X-School-ID header on metrics requests.
PUBLIC_SCHOOL_ID=37

# Optional explicit careers endpoint override.
# If empty, landing app defaults to: <PUBLIC_MAIN_APP_API_BASE_URL>/api/public/careers/apply/
PUBLIC_CAREERS_FORM_ENDPOINT=

# Optional explicit demo form endpoint override.
# If empty, landing app defaults to: <PUBLIC_MAIN_APP_API_BASE_URL>/api/public/forms/demo-request/
PUBLIC_DEMO_FORM_ENDPOINT=

# Optional explicit contact form endpoint override.
# If empty, landing app defaults to: <PUBLIC_MAIN_APP_API_BASE_URL>/api/public/forms/contact-enquiry/
PUBLIC_CONTACT_FORM_ENDPOINT=
