# =============================================================================
# KoderEduAI Frontend - Environment Variables
# =============================================================================
# For local development, you typically do NOT need to set this.
# The Vite dev server proxy (vite.config.js) handles /api routing to localhost:8000.
#
# For production (Render), set this to your backend URL:
#   VITE_API_URL=https://kodereduai-api.onrender.com
# =============================================================================

VITE_API_URL=

# React Query cache defaults (optional)
VITE_QUERY_STALE_TIME_MS=30000
VITE_QUERY_GC_TIME_MS=300000
VITE_QUERY_REFETCH_ON_WINDOW_FOCUS=true
VITE_QUERY_RETRY_COUNT=1

# Login preload (safe defaults)
# Keep disabled until rollout starts.
VITE_LOGIN_PRELOAD_ENABLED=false
VITE_LOGIN_PRELOAD_MAX_CONCURRENCY=3
VITE_LOGIN_PRELOAD_TIMEOUT_MS=6000
VITE_LOGIN_PRELOAD_DEBUG=false
VITE_LOGIN_PRELOAD_TIER_B_ENABLED=true
VITE_LOGIN_PRELOAD_TIER_B_DELAY_MS=1200
VITE_LOGIN_PRELOAD_TELEMETRY_ENABLED=true
VITE_LOGIN_PRELOAD_TELEMETRY_MAX_EVENTS=25
